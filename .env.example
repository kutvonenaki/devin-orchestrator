# Copy to .env and fill in. Only DEVIN_* are strictly required for a live run.
# The offline test suite needs NONE of these (all external calls are mocked).
# IMPORTANT: never put an inline "# comment" after a value — python-dotenv
# treats everything after = as the value. Keep comments on their own lines.

# --- Devin (required for live run) ---
DEVIN_API_KEY=
DEVIN_ORG_ID=

# --- GitHub ---
# Token is OPTIONAL and the app does not need it: the fork is public, so
# issue reads are unauthenticated. Leave GITHUB_TOKEN empty unless you want
# the PR-link comment-back (Devin's PR auto-links the issue regardless).
GITHUB_REPO=kutvonenaki/superset
GITHUB_TOKEN=
ISSUE_LABEL=devin

# --- timing (optional; sensible defaults in app/config.py) ---
# GitHub-facing polls are deliberately slow (5 min): token-free against a
# public fork, so we stay under the unauthenticated rate limit.
POLL_INTERVAL_SECONDS=180
PR_COMMENT_POLL_INTERVAL_SECONDS=180
DEVIN_POLL_INTERVAL_SECONDS=60
MAX_POLL_MINUTES=45

# --- app (optional) ---
DATA_DIR=./data
PORT=8000
